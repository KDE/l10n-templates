msgid "TV-Friendly Interface"
msgstr ""

#. feature-privacy-desc
#. +> trunk5
#: i18n/en.yaml:46
msgid "Control your computer from the couch. Launch apps, change settings, and switch between running applications, all through an interface designed for the big screen."
msgstr ""

#. feature-open-title
#. +> trunk5
#: i18n/en.yaml:48
msgid "Fully Open Source"
msgstr ""

#. feature-open-desc
#. +> trunk5
#: i18n/en.yaml:50
msgid "Built on open-source technologies like <a href=\"https://kde.org/plasma-desktop\">KDE Plasma</a>, <a href=\"https://invent.kde.org/plasma/kwin\">KWin</a>, <a href=\"https://kde.org/products/frameworks/\">KDE Frameworks</a>, <a href=\"https://www.qt.io/\">Qt</a>, and <a href=\"https://kde.org/products/kirigami/\">Kirigami</a>. Browse our source code on <a href=\"https://invent.kde.org/plasma/plasma-bigscreen\">KDE Invent</a>."
msgstr ""

#. feature-flexible-title
#. +> trunk5
#: i18n/en.yaml:52
msgid "Flexible And Customizable"
msgstr ""

#. feature-flexible-desc
#. +> trunk5
#: i18n/en.yaml:54
msgid "Based on the <a href=\"https://kde.org/plasma-desktop/\">most flexible desktop</a> in the world, your TV truly becomes your own. Install apps, tweak and customize the entire system to your liking."
msgstr ""

#. feature-control-title
#. +> trunk5
#: i18n/en.yaml:56
msgid "Multiple Input Methods"
msgstr ""

#. feature-control-desc
#. +> trunk5
#: i18n/en.yaml:58
msgid "Navigate with your TV remote via CEC, a game controller, a keyboard and mouse, or even your phone via <a href=\"https://kdeconnect.kde.org/\">KDE Connect</a>."
msgstr ""

