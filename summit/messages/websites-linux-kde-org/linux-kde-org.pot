#. +> trunk5
#: content/docs/multi-gpu.md:13
msgid "If this isn’t working as expected, here are some methods for forcing apps to use the more powerful GPU:"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:16
msgid "Persistent change, using Menu Editor"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:17
msgid "This method will force the app to use the dedicated GPU every time it’s launched from within KDE Plasma or any other app."
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:19
msgid "Launch the _Menu Editor_ app"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:20
msgid "In the sidebar, locate the misbehaving app"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:21
msgid "Click the “Advanced” tab"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:22
msgid "Check the “Run using dedicated graphics card” checkbox"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:23
msgid "Click “Save”."
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:26
msgid "Persistent change for Steam Games"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:27
msgid "This method will force the game to use the dedicated GPU every time it’s launched from Steam."
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:29
msgid "Locate the game on your “Library” page and click it"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:30
msgid "Click the gear icon and select “Properties”"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:31
msgid ""
"If your dedicated GPU is from AMD or Intel, enter:"
"<pre>DRI_PRIME=1 %command%</pre>"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:32
msgid ""
"If your dedicated GPU is from NVIDIA, enter:"
"<pre>__NV_PRIME_RENDER_OFFLOAD=1 __VK_LAYER_NV_optimus=NVIDIA_only __GLX_VENDOR_LIBRARY_NAME=nvidia %command%</pre>"
msgstr ""

#. +> trunk5
#: content/docs/multi-gpu.md:35
msgid "Temporary change, using the command-line"
