msgid "[DSK]ReadKBTot = Disk - Kilobytes read/s"
msgstr ""

#. +> trunk5
#: content/be4foss-handbook/handbook_web.md:644
msgid "[DSK]WriteKBTot = Disk - kilobytes written/s."
msgstr ""

