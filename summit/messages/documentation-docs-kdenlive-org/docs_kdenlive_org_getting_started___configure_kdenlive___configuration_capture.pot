#: ../../getting_started/configure_kdenlive/configuration_capture.rst:23
msgid "Capture"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:25
msgid "This section configures the capturing of audio and video. Kdenlive allows to capture video using :doc:`ScreenGrab </project_and_asset_management/capturing_video>` and a |blackmagic| |decklink| card, and :doc:`audio </project_and_asset_management/capturing_audio>` with the devices available on your system."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:30
msgid "ScreenGrab"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:36
msgid "Configure section Capture: ScreenGrab with Rectangular Region selected"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:38
msgid ":guilabel:`Region to Capture`. Default is **Full screen**. Selecting **Rectangular Region** opens a panel with additional parameters (as shown in the figure above)."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:40
msgid ":guilabel:`Follow mouse`. If checked, the defined rectangular follows the mouse. :guilabel:`Hide Frame`. If checked, makes the frame defined by the parameters below invisible."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:42
msgid ":guilabel:`Offset` - Distance along the x (first parameter) and y axis (second parameter) from the top left corner of the screen. :guilabel:`Size` - Width (first parameter) and height (second parameter) of the rectangle."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:44
msgid ":guilabel:`Mouse cursor`. If checked, the mouse pointer will not be recorded."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:46
msgid ":guilabel:`Frame rate`. Set the frame rate (fps) for the recording."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:48
msgid ":guilabel:`Encoding profile`. Clicking on |configure|\\ :guilabel:`Show profile parameters` opens the **Manage Encoding profiles** dialog window (see yellow arrow) to manage the available profiles. Click on |help-about| to display the ffmpeg parameters used in the selected profile."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:54
msgid "Blackmagic"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:56
msgid "If you have a |blackmagic| |decklink| video capture card you can set here the import parameter."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:62
msgid "Configure section Capture: Blackmagic DeckLink (encoding parameter window open)"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:64
msgid ":guilabel:`Detected devices`. Lists the devices you can choose from."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:66
msgid ":guilabel:`Encoding profile`. Select the profile to be used for encoding the recording. Clicking on |configure|\\ :guilabel:`Show profile parameters` opens the **Manage Encoding profiles** dialog window (see yellow arrow) to manage the available profiles. Click on |help-about| to display the ffmpeg parameters used in the selected profile."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:68
msgid ":guilabel:`Capture file name`. Enter the name under which the recording shall be saved to the folder defined in the Environment section."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:70
msgid "List of available encoding profile for DeckLink Capture."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:72
msgid "ffmpeg parameters for the selected profile"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:74
msgid "Click on |list-add| to create a new profile based on the selected one, |document-edit| to edit the selected profile, |edit-delete| to delete the selected profile. |edit-download| does not have a function yet."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:80
msgid "Audio"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:86
msgid "These settings are for configuring the audio device that is used during screen recording and for recording of voice overs. See the chapter about :doc:`Capturing Audio </project_and_asset_management/capturing_audio>`."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:93
msgid ":guilabel:`Device`. Select the device to be used for recording audio."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:95
msgid ":guilabel:`Capture volume`. Use the slider to adjust the volume for the recording."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:97
msgid ":guilabel:`Use Device Default Settings`. This will set the channels, sample rate and sample formats to the device's default,"
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:99
msgid ":guilabel:`Channels`. Select how many channels you want to record. Options are **Stereo (2 channels)** (default), and **Mono (1 channel)**. It only displays values supported by the selected hardware."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:101
msgid ":guilabel:`Sample rate`. Select the sample rate for the recording. Options are **48,000Hz** (default) and **44,100Hz** and **96,000Hz**. It only displays values supported by the selected hardware."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:103
msgid ":guilabel:`Sample format`. Try one of this options if recording is not working properly. Options are **8bit** , **16bit**, **32bit**, and **float**."
msgstr ""

#. +> trunk5
#: ../../getting_started/configure_kdenlive/configuration_capture.rst:105
msgid ":guilabel:`Disable countdown before recording`. If checked, recording will start immediately upon pressing the record button in the audio track (see :doc:`Capturing Audio </project_and_asset_management/capturing_audio>`). By default, a three-second countdown will be used and displayed in the project monitor."
msgstr ""

