#. Tag: title
#. +> trunk6
#: index.docbook:62
#, no-c-format
msgid "Basic Usage"
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:64
#, no-c-format
msgid "Creating a New Tournament"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:65
#, no-c-format
msgid "To create a new &chessament; tournament, select <menuchoice><guimenu>File</guimenu><guimenuitem>New…</guimenuitem></menuchoice>, enter a name, choose the number of rounds, and click <guibutton>Save</guibutton>. You will be asked to choose a location where you want to save the tournament."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:73
#, no-c-format
msgid "Registering Players"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:74
#, no-c-format
msgid "To add a new player to the tournament click on the <guibutton>Add Player…</guibutton> button in the toolbar."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:80
#, no-c-format
msgid "Pairings &amp; Results"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:81
#, no-c-format
msgid "After you have finished registering all the players of the tournament, you can now make the pairings for the first round. Go to the <guibutton>Pairings</guibutton> view and click on the <guibutton>Pair Round 1…</guibutton> button. A dialog will appear where you can customize some options for the first round. It is recommended that you leave the <guibutton>Sort players</guibutton> option enabled. You can choose the color of the pieces of the highest ranked player, or let &chessament; choose a random color for you."
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:88
#, no-c-format
msgid "To enter the results, click on a pairing and choose from one of the supported results at the bottom. You can also enter the results using the keyboard. Pressing <keycap>1</keycap> sets the result to White wins, <keycap>0</keycap> to Black wins and <keycap>5</keycap> to draw. After entering a result, the next pairing without a result is automatically selected."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:96
#, no-c-format
msgid "Viewing Standings"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:97
#, no-c-format
msgid "To view the standings of the tournament, go to the <guibutton>Standings</guibutton> view. From there you can choose to view the final standings or the standings from a previous round."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:105
#, no-c-format
msgid "Tournaments"
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:107
#, no-c-format
msgid "Settings"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:108
#, no-c-format
msgid "To open the settings window of a tournament, click on the <guibutton>Settings</guibutton> button at the bottom of the &chessament; window. This section describes the available options in details."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:113
#, no-c-format
msgid "Information"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:114
#, no-c-format
msgid "In this section you can set some basic information such as the tournament's name, location, and arbiters."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:119
#, no-c-format
msgid "Format"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:120
#, no-c-format
msgid "In this section you can configure the number of rounds of the tournament and the tiebreaks used for calculating the standings. More information about the tiebreaks is available in the <link linkend=\"tournament-tiebreaks\">Tiebreaks</link> section."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:127
#, no-c-format
msgid "Calendar"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:128
#, no-c-format
msgid "In this section you can set the tournament's schedule."
msgstr ""

#. Tag: title
#. +> trunk6
#: index.docbook:134
#, no-c-format
msgid "Tiebreaks"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:135
#, no-c-format
msgid "&chessament; supports the following tiebreaks as described in the <ulink url=\"https://handbook.fide.com/\"><acronym>FIDE</acronym> Handbook</ulink>:"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:141
#, no-c-format
msgid "Average Buchholz of Opponents (<acronym>AOB</acronym>)"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:144
#, no-c-format
msgid "Buchholz (<acronym>BH</acronym>)"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:147
#, no-c-format
msgid "Number of Games Played with Black (<acronym>BPG</acronym>)"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:150
#, no-c-format
msgid "Number of Games Won (over the board) (<acronym>WON</acronym>)"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:153
#, no-c-format
msgid "Number of Wins (<acronym>WIN</acronym>)"
msgstr ""

#. Tag: para
#. +> trunk6
#: index.docbook:156
#, no-c-format
msgid "Points (<acronym>PTS</acronym>)"
msgstr ""

